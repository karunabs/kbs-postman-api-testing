    {
      "name": "GET Single User (Positive Test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is under 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains data array\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.data.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Each user has required fields\", function() {\r",
              "    var users = pm.response.json().data;\r",
              "\r",
              "    users.forEach(function(user) {\r",
              "        pm.expect(user).to.have.property(\"id\")\r",
              "        pm.expect(user).to.have.property(\"email\")\r",
              "        pm.expect(user).to.have.property(\"last_name\")\r",
              "        pm.expect(user).to.have.property(\"first_name\")\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Email format is valid\", function() {\r",
              "    var users = pm.response.json().data;\r",
              "\r",
              "    users.forEach(function(user) {\r",
              "        pm.expect(user.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"status code is 200\", function() {\r",
              "    pm.response.to.have.status(200)\r",
              "});\r",
              "\r",
              "pm.test(\"returned user ID is 2\", function() {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data.id).to.eql(2);\r",
              "});\r",
              "\r",
              "pm.test(\"status code is 404 for non-existing user\", function () {\r",
              "   pm.response.to.have.status(404)\r",
              "});\r",
              "\r",
              "pm.test(\"Status code is 201\", function() {\r",
              "    pm.response.to.have.status(201)\r",
              "});\r",
              "\r",
              "pm.test(\"user is created with correct data\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.name).to.eql(\"testuser\");\r",
              "    pm.expect(jsonData.job).to.eql(\"IT Pro\");\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response contains id and createdAt\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
              "    pm.expect(jsonData).to.have.property(\"createdAt\");\r",
              "});\r",
              "\r",
              "pm.test(\"Status code is 204\", function () {\r",
              "    pm.response.to.have.status(204)\r",
              "});\r",
              ""
            ],
